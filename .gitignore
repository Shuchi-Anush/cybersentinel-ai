# Python
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/

# Environment
.env

# Data (keep structure, ignore content)
data/raw/*
!data/raw/*.dvc
!data/raw/.gitkeep

data/processed/*
!data/processed/*.dvc
!data/processed/.gitkeep

# Models (keep structure only)
models/*
!models/.gitignore

# Artifacts (keep structure only)
artifacts/*
!artifacts/.gitkeep

# Logs
logs/*
!logs/.gitkeep

# MLflow
mlruns/*
!mlruns/.gitkeep
mlflow.db

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Lint / debug
ruff_errors*.json
*.tmp

# IMPORTANT: DO NOT ignore all JSON
# configs/*.json must be tracked

outputs/*
!outputs/.gitkeep