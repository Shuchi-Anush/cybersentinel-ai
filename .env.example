# CyberSentinel-AI Production Configuration Example
# Copy this to .env and adjust as needed

# Server Config
APP_HOST=0.0.0.0
APP_PORT=8000

# ML Config
# Default path assumes models are mounted at /app/models in Docker
MODEL_PATH=/app/models

# Observability
# Options: debug, info, warning, error, critical
LOG_LEVEL=info
BINARY_THRESHOLD=0.3
